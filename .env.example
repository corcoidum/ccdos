# 모든 값은 로컬 환경 또는 CI Secret에서만 설정합니다. 실제 값은 커밋하지 않습니다.
# DISCORD_WEBHOOK_URL=
# 릴리스 노트 채널 webhook (로컬 전용 — docs/runbooks/discord-release-notes.md).
# DISCORD_RELEASE_WEBHOOK_URL=
# 아이디어 인박스 (로컬 전용 — docs/runbooks/discord-idea-inbox.md). CI에는 설정하지 않습니다.
# DISCORD_BOT_TOKEN=
# DISCORD_IDEAS_CHANNEL_ID=
# IDEAS_INBOX_DIR=
# OpenAI Platform과 Cloudflare Worker에서만 Secret으로 설정합니다. 실제 값을 저장소에 기록하지 않습니다.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# DAILY_ANSWER_LIMIT=200
# PUBLIC_SITE_URL=https://ccdos.corcoidum.workers.dev
