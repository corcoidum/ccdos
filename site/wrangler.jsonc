{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ccdos",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "OPENAI_MODEL": "gpt-5.4-mini",
    "DAILY_ANSWER_LIMIT": "200",
    // 일시적 진단용. 원인 확인 후 제거한다.
    "ANSWER_DEBUG": "1"
  },
  "secrets": {
    "required": ["OPENAI_API_KEY"]
  },
  "ratelimits": [
    {
      "name": "ANSWER_RATE_LIMITER",
      "namespace_id": "819347",
      "simple": { "limit": 6, "period": 60 }
    },
    {
      "name": "ANSWER_GLOBAL_LIMITER",
      "namespace_id": "819348",
      "simple": { "limit": 30, "period": 60 }
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DAILY_ANSWER_BUDGET",
        "class_name": "DailyAnswerBudget"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DailyAnswerBudget"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
