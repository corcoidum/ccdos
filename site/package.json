{
  "name": "corcoidum-os-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:worker": "npm run build && wrangler dev --local --ip 127.0.0.1 --port 4173 --log-level error",
    "build": "vite build",
    "types": "wrangler types",
    "typecheck": "npm run types && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "preview": "vite preview --host 127.0.0.1",
    "test": "playwright test",
    "cf:whoami": "wrangler whoami",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.110.0"
  }
}
